# Supabase — Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Anthropic — https://console.anthropic.com/settings/keys
# Solo se usa en API routes del servidor. Nunca se expone al cliente.
ANTHROPIC_API_KEY=

# Opcional: modelo de Claude. Por defecto claude-sonnet-4-20250514.
# AVISO: claude-sonnet-4-20250514 se retira el 15/06/2026 — usa claude-sonnet-4-6 a partir de entonces.
# CLAUDE_MODEL=claude-sonnet-4-6
